{
  "compilerOptions": {
    "module": "commonjs",
    "target": "es2020",
    "strict": true,
    "esModuleInterop": true,
    "moduleResolution": "node",
    "resolveJsonModule": true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true,
    "types": [
      "node",
      "vitest/globals"
    ],
    "paths": {
      "@orecce/api-core/src/*": [
        "../../packages/api-core/src/*"
      ]
    }
  },
  "include": [
    "src/**/*.ts",
    "api/**/*.ts",
    "tests/**/*.ts",
    "scripts/**/*.ts"
  ]
}