{
  "name": "ai-post-functions",
  "private": true,
  "main": "lib/server.js",
  "engines": {
    "node": "22"
  },
  "scripts": {
    "build": "npm run clean && tsc -p tsconfig.build.json",
    "clean": "rm -rf lib",
    "corpus:generate": "tsx scripts/generate-spec-corpus.ts",
    "corpus:posts": "tsx scripts/generate-spec-corpus.ts --stage posts",
    "corpus:titles": "tsx scripts/generate-spec-corpus.ts --stage briefs",
    "posts:tier1-samples": "tsx scripts/generate-tier1-post-samples.ts",
    "titles:curate": "tsx scripts/generate-curated-title-library.ts",
    "titles:generate": "tsx scripts/generate-spec-titles.ts",
    "titles:trim": "tsx scripts/trim-curated-title-library.ts",
    "start": "node lib/server.js",
    "dev:generate": "tsx scripts/dev-generate.ts",
    "dev:server": "tsx scripts/dev-server.ts",
    "dev:supabase": "tsx src/server.ts",
    "lint:types": "tsc --noEmit -p tsconfig.json",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@orecce/api-core": "file:../../../packages/api-core",
    "@supabase/supabase-js": "^2.49.1",
    "cors": "^2.8.5",
    "dotenv": "^17.3.1",
    "express": "^4.21.2",
    "fast-xml-parser": "^4.5.3",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^22.13.0",
    "tsx": "^4.21.0",
    "typescript": "^5.7.3",
    "vite-tsconfig-paths": "^6.1.1",
    "vitest": "^3.0.5"
  }
}
