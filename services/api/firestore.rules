rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // User-scoped docs and subcollections are accessible only to the owner.
    match /users/{userId} {
      allow read, write: if isOwner(userId);

      match /{document=**} {
        allow read, write: if isOwner(userId);
      }
    }

    // Deny all other direct client access. Backend access happens via Admin SDK.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
